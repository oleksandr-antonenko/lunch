{
  "name": "lunch",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @lunch/web dev\" \"pnpm --filter @lunch/api start:dev\"",
    "build": "pnpm --filter @lunch/shared build && pnpm --filter @lunch/api build && pnpm --filter @lunch/api-client build && pnpm --filter @lunch/web build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=20"
  }
}
