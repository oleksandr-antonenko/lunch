generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────

enum UserRole {
  MEMBER
  MANAGER
  ADMIN
}

enum OrderStatus {
  OPEN
  RECEIPT_UPLOADED
  ITEMS_ASSIGNED
  CLOSED
}

enum DebtType {
  CHARGE
  PAYMENT
}

enum PaymentProofStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseStatus {
  OPEN
  CLAIMED
  RECEIPT_UPLOADED
  REIMBURSED
}

// ── User ───────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email         String    @unique
  name          String
  emailVerified Boolean   @default(false)
  image         String?
  avatarUrl     String?
  role          UserRole  @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  orders           Order[]        @relation("organizer")
  orderItems       OrderItem[]    @relation("assignedTo")
  debtsOwed        Debt[]         @relation("debtor")
  debtsOwedTo      Debt[]         @relation("creditor")
  expenses         Expense[]      @relation("expenseCreator")
  claimedExpenses  Expense[]      @relation("expenseClaimant")
  paymentProofsFrom PaymentProof[] @relation("proofFrom")
  paymentProofsTo   PaymentProof[] @relation("proofTo")
  reviewedProofs    PaymentProof[] @relation("proofReviewer")

  // better-auth relations
  sessions Session[]
  accounts Account[]
}

// ── better-auth tables ─────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Order ──────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  title           String
  organizerId     String
  status          OrderStatus @default(OPEN)
  receiptImageUrl String?
  rawReceiptData  Json?
  totalAmountCents Int        @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organizer     User           @relation("organizer", fields: [organizerId], references: [id])
  items         OrderItem[]
  paymentProofs PaymentProof[]
  debts         Debt[]

  @@index([organizerId])
  @@index([status])
}

// ── OrderItem ──────────────────────────────────────────

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  assignedToId String?
  description  String
  amountCents  Int
  quantity     Int      @default(1)
  createdAt    DateTime @default(now())

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("assignedTo", fields: [assignedToId], references: [id])

  @@index([orderId])
  @@index([assignedToId])
}

// ── Debt ───────────────────────────────────────────────

model Debt {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  amountCents Int
  orderId     String?
  reason      String
  type        DebtType
  createdAt   DateTime @default(now())

  fromUser User  @relation("debtor", fields: [fromUserId], references: [id])
  toUser   User  @relation("creditor", fields: [toUserId], references: [id])
  order    Order? @relation(fields: [orderId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
}

// ── PaymentProof ───────────────────────────────────────

model PaymentProof {
  id           String             @id @default(cuid())
  fromUserId   String
  toUserId     String
  orderId      String?
  amountCents  Int
  imageUrl     String
  status       PaymentProofStatus @default(PENDING)
  reviewedById String?
  createdAt    DateTime           @default(now())

  fromUser   User  @relation("proofFrom", fields: [fromUserId], references: [id])
  toUser     User  @relation("proofTo", fields: [toUserId], references: [id])
  order      Order? @relation(fields: [orderId], references: [id])
  reviewedBy User? @relation("proofReviewer", fields: [reviewedById], references: [id])

  @@index([fromUserId])
  @@index([status])
}

// ── Expense ────────────────────────────────────────────

model Expense {
  id                  String        @id @default(cuid())
  title               String
  description         String?
  estimatedAmountCents Int
  actualAmountCents   Int?
  status              ExpenseStatus @default(OPEN)
  createdById         String
  claimedById         String?
  receiptImageUrl     String?
  reimbursedAt        DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  createdBy User  @relation("expenseCreator", fields: [createdById], references: [id])
  claimedBy User? @relation("expenseClaimant", fields: [claimedById], references: [id])

  @@index([status])
  @@index([claimedById])
}
